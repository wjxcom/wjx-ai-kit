{
  "name": "wjx-mcp-server",
  "version": "2.1.0",
  "description": "问卷星 (Wenjuanxing) OpenAPI MCP Server — 创建、查询、管理问卷",
  "main": "dist/index.js",
  "files": ["dist", "README.md", ".env.example"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "test": "npm run build && node --test __tests__/*.test.mjs tests/*.test.mjs",
    "test:unit": "npm run build && node --test __tests__/*.test.mjs",
    "test:integration": "npm run build && node --test tests/*.test.mjs",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "wjx"
  ],
  "author": "wjxagents",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
